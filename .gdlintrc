# gdlint configuration for godotty
# See: https://github.com/Scony/godot-gdscript-toolkit/wiki/3.-Linter
#
# All disable exceptions removed in task 0.4.2 — underlying code issues fixed.

# Naming — allow leading underscore for lifecycle / private (_ready, _on_xxx, ...).
function-name: '(_on_)?_?[a-z][a-z0-9]*(_[a-z0-9]+)*'
class-variable-name: '[a-z_][a-z0-9_]*'
constant-name: '[A-Z][A-Z0-9_]*'

# Function size
max-file-lines: 850
function-arguments-number: 6
# GdUnit4 test suites accumulate many test_ methods by design; raise the cap.
max-public-methods: 100
