# gdlint configuration for godotty
# See: https://github.com/Scony/godot-gdscript-toolkit/wiki/3.-Linter

# Disable a few rules that are noisy for this codebase. Re-enable on a
# per-file basis with inline comments if needed.
disable:
  - max-public-methods           # autoloads naturally have many
  - class-definitions-order      # we follow our own order in gdscript-style skill
  - max-line-length              # gdformat handles wrapping
  - private-method-call          # we routinely test private mock helpers

# Naming
function-name: '(_on_)?[a-z][a-z0-9]*(_[a-z0-9]+)*'
class-variable-name: '[a-z_][a-z0-9_]*'
constant-name: '[A-Z][A-Z0-9_]*'

# Function size
max-file-lines: 600
function-arguments-number: 6
